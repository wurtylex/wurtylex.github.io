---
import Base from './Base.astro';
import '../styles/main.css';

const { frontmatter } = Astro.props;

const pubDateRaw = frontmatter.date ? new Date(frontmatter.date) : new Date();
const pubDate = pubDateRaw.toISOString().slice(0, 10);

const updatedDateRaw = frontmatter.lastUpdated ? new Date(frontmatter.lastUpdated) : null;
const updatedDate = updatedDateRaw ? updatedDateRaw.toISOString().slice(0, 10) : null;

const isRevised = updatedDate && updatedDate !== pubDate;
---

<Base title={frontmatter.title} description={frontmatter.description}>
  <article>
    <p style="margin-bottom: 2rem;">
      <a href="/">← index</a>
    </p>
    <h1>{frontmatter.title}</h1>

    <p class="subtitle">
      {frontmatter.description}
      <br />
      <span style="display: block; margin-top: 0.5rem; opacity: 0.7; font-size: 0.9em;">
        Published: <time datetime={pubDate}>{pubDate}</time>
        {isRevised && (
          <>
            &nbsp; &middot; &nbsp;
            Last Updated: <time datetime={updatedDate}>{updatedDate}</time>
          </>
        )}
      </span>
    </p>

    <section>
      <slot />
    </section>
  </article>
</Base>

<style>
  /* Ensuring the subtitle stays within Tufte's main column bounds */
  .subtitle {
    margin-top: 1rem;
    margin-bottom: 2rem;
    line-height: 1.4;
  }
  
  time {
    font-variant-numeric: tabular-nums;
  }
</style>
