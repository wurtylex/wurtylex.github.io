---
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/png" href="/32by32.png" />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    />
  </head>

  <body>
    <slot />
  </body>

  <footer style="margin-top: 4rem; padding: 2rem 0; border-top: 1px solid #e8e2d8; font-size: 0.8em; opacity: 0.5;">
    <p>© {new Date().getFullYear()} wurtylex · Built with <a href="https://astro.build">astro</a> </p>
  </footer>

  <meta name="author" content="wurtylex" />
  <meta name="copyright" content="wurtylex" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
</html>
