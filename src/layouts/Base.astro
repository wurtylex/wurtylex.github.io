---
const { title, description } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="wurtylex" />
    <meta name="copyright" content="wurtylex" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/png" href="/32by32.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  </head>
  <body>
    <div style="text-align: right; padding: 0rem 0rem 0;">
    <button id="theme-toggle" style="
      background: transparent;
      border: 1px solid currentColor;
      border-radius: 3px;
      padding: 3px 10px;
      font-family: inherit;
      font-size: 11px;
      cursor: pointer;
      opacity: 0.5;
      z-index: 9999;
    ">carapace</button>
    </div>
    <slot />
    <footer style="margin-top: 2rem; padding: 0rem 0; border-top: 1px solid var(--border-color); font-size: 0.8em; opacity: 0.5;">
      <p>© {new Date().getFullYear()} wurtylex · Built with <a href="https://astro.build">Astro</a></p>
    </footer>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('theme-toggle');
        const root = document.documentElement;
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        const saved = localStorage.getItem('theme');
        if (saved === 'dark') {
          root.setAttribute('data-theme', 'dark');
          toggle.textContent = 'plastron';
        } else if (saved === 'light') {
          root.setAttribute('data-theme', 'light');
          toggle.textContent = 'carapace';
        } else {
          toggle.textContent = systemDark ? 'plastron' : 'carapace';
        }

        toggle.addEventListener('click', () => {
          const current = root.getAttribute('data-theme');
          const isDark = current === 'dark' || (!current && systemDark);
          if (isDark) {
            root.setAttribute('data-theme', 'light');
            localStorage.setItem('theme', 'light');
            toggle.textContent = 'carapace';
          } else {
            root.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
            toggle.textContent = 'plastron';
          }
        });
      });
    </script>
  </body>
</html>
