---
import Base from '../layouts/Base.astro';
import '../styles/tufte-overrides.css';

const postFiles = import.meta.glob('./**/index.mdx', { eager: true });
const posts = Object.values(postFiles) as any[];
const sorted = posts.sort((a, b) =>
  new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);
---

<Base title="wurtylex">
  <article>
    <h1>wurtylex</h1>
    <section>
      {sorted.map(post => (
        <p>
          <a href={post.url}>{post.frontmatter.title}</a>
          <br />
          <span style="font-size: 0.85em; opacity: 0.6;">
            {new Date(post.frontmatter.date).toISOString().slice(0, 10)}
            {post.frontmatter.description && ` — ${post.frontmatter.description}`}
          </span>
        </p>
      ))}
    </section>
  </article>
</Base>
